# Copy this file to .env and fill in your keys
# Never commit .env to git

# Reactor Helios — for AI avatar video streaming
REACTOR_API_KEY=rk_...
# Option B: multiple keys (comma-separated)
# REACTOR_API_KEYS=rk_...,rk_...
# Max concurrent streams per key (default 5)
# ODYSSEY_KEY_LIMIT=5
# Lease TTL in ms (default 2 hours)
# ODYSSEY_LEASE_TTL_MS=7200000

# Upstash Redis — for shared key-pool state across Vercel serverless instances
# Add via Vercel Marketplace → Upstash Redis integration, then copy the env vars it sets.
# Without these, the pool falls back to in-memory (fine for local dev, broken on Vercel).
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Google Gemini — for gesture detection and character intelligence
GEMINI_API_KEY=AIza...

# Smallest AI — for voice synthesis and cloning
SMALLEST_API_KEY=sk_...

# Supabase — for auth and database
# Get these from: supabase.com → your project → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-side only, never expose to browser

# Supabase — client-side (Vite exposes VITE_ prefix vars to the browser)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Voice clone A/B test providers
FISH_AUDIO_API_KEY=
GRADIUM_API_KEY=
SARVAM_API_KEY=

# CORS: comma-separated list of allowed origins in production
ALLOWED_ORIGINS=https://interactstudio.space,https://www.interactstudio.space

# Optional: override the AI model used for character chat
# EINSTEIN_MODEL=gemini-2.5-flash

# Local dev only
PORT=8787

# PostHog — for product analytics
VITE_POSTHOG_KEY=phc_...
VITE_POSTHOG_HOST=https://us.i.posthog.com
