# Copy this file to .env and fill in your keys
# Never commit .env to git

# Odyssey ML — for AI avatar video streaming
ODYSSEY_API_KEY=ody_...

# Google Gemini — for gesture detection and character intelligence
GEMINI_API_KEY=AIza...

# Smallest AI — for voice synthesis and cloning
SMALLEST_API_KEY=sk_...

# CORS: comma-separated list of allowed origins in production
ALLOWED_ORIGINS=https://interactstudio.space,https://www.interactstudio.space

# Optional: override the AI model used for character chat
# EINSTEIN_MODEL=gemini-2.0-flash

# Local dev only
PORT=8787
