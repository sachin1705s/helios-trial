{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "ignoreCommand": "git diff --name-only HEAD^ HEAD | grep -qv '^docs/'",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server" }
  ],
  "functions": {
    "api/server.js": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
