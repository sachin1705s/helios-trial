{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "ignoreCommand": "! git diff --name-only HEAD^ HEAD | grep -qvE '^docs/'",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server" },
    { "source": "/about-us", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/", "destination": "/index.html" }
  ],
  "functions": {
    "api/server.js": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
